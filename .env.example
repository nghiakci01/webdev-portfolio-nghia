# Application Environment
NODE_ENV=development

# ============================================
# EmailJS Configuration (Optional)
# ============================================
# Get these from https://www.emailjs.com (Account > API Keys)
# Leave empty or comment out to disable email functionality
VITE_EMAILJS_SERVICE_ID=service_your_service_id
VITE_EMAILJS_TEMPLATE_ID=template_your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# ============================================
# Google Analytics Configuration (Optional)
# ============================================
# Get this from Google Analytics (Admin > Property > Data Streams)
# Format: G-XXXXXXXXXX
# Leave empty to disable analytics
VITE_GOOGLE_ANALYTICS_ID=

# ============================================
# Application Configuration
# ============================================
# Site URL (used for Open Graph and canonical tags)
VITE_SITE_URL=https://yourportfolio.com

# API endpoints (if needed for future backend integration)
VITE_API_URL=https://api.yoursite.com
VITE_API_TIMEOUT=30000
